{
    "name": "volunteer-engagement-portal",
    "private": true,
    "version": "2.0.0",
    "type": "module",
    "engines": {
        "node": ">=20.18.1 <25"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:dev": "vite build --mode development",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:typecheck": "tsc --project tsconfig.test.json",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
        "preview": "vite preview",
        "deploy": "npm run build && pac pages upload-code-site --rootPath . && npm run permissions:patch-roles && npm run permissions:patch-bot-roles",
        "sync": "pwsh -NoProfile -File ./scripts/site-admin/sync-power-pages-site.ps1",
        "permissions:patch-roles": "pwsh -NoProfile -File ./scripts/permissions/patch-table-permission-roles.ps1",
        "permissions:patch-bot-roles": "pwsh -NoProfile -File ./scripts/permissions/patch-bot-consumer-roles.ps1",
        "site:restart": "pwsh -NoProfile -File ./scripts/site-admin/restart-power-pages-site.ps1"
    },
    "dependencies": {
        "@fluentui/react-components": "^9.56.0",
        "@fluentui/react-icons": "^2.0.258",
        "dompurify": "^3.4.7",
        "html-react-parser": "^6.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.30.3"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "@types/node": "^22.15.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "axe-core": "^4.12.0",
        "eslint": "^8.0.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.2.0",
        "typescript": "^5.0.0",
        "vite": "^6.4.1",
        "vitest": "^4.1.8"
    }
}
