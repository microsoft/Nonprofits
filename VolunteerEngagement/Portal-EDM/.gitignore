node_modules/
dist/
*.local
.env

# Environment-specific Power Pages setting generated by sync.
.powerpages-site/site-settings/SiteUrl.sitesetting.yml

# Generated Vite bundle web-files. `npm run deploy` recreates these from dist/ and
# rewrites their environment-specific annotation IDs on every upload, so they are not
# tracked. Authored stock assets under web-files/ (favicon, theme, profile, etc.) stay tracked.
.powerpages-site/web-files/index.html/
.powerpages-site/web-files/index.css/
.powerpages-site/web-files/index.js/
.powerpages-site/web-files/vendor-fluent-components.js/
.powerpages-site/web-files/vendor-fluent-icons.js/
.powerpages-site/web-files/vendor-react.js/
