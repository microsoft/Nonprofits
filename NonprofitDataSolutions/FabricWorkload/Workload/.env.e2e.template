# =============================================================================
# E2E Test Environment Configuration
# =============================================================================
# Copy this file to .env.e2e and fill in your values.
# NEVER commit .env.e2e with real credentials.
# =============================================================================

# Microsoft Fabric base URL
FABRIC_BASE_URL=https://app.fabric.microsoft.com

# Workspace where the Fundraising item is deployed
E2E_WORKSPACE_ID=your-workspace-id-here

# Authentication — choose one of the three methods below:
#
# Method 1: Interactive login (default for local dev)
# Leave E2E_AUTH_METHOD empty or set to "interactive"
#
# Method 2: Certificate-based (recommended for CI/CD)
# Set E2E_AUTH_METHOD=certificate
# Playwright enters the email and presents the PFX cert to Entra ID
#
# Method 3: Username + Password (CI fallback)
# Set E2E_AUTH_METHOD=credential
E2E_AUTH_METHOD=interactive
E2E_USERNAME=
E2E_PASSWORD=

# Certificate auth settings (Method 2)
E2E_CERT_PFX_PATH=
E2E_CERT_PASSPHRASE=
