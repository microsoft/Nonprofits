{
	"name": "nonprofit-data-solutions-fabric-workload",
	"version": "1.0.0",
	"engines": {
		"node": ">=22.17.1"
	},
	"description": "Microsoft Fabric - Nonprofit data solutions in Microsoft Fabric Workload",
	"license": "MIT",
	"scripts": {
		"start": "npm run start:devServer",
		"start:devServer": "env-cmd -f .env.dev webpack serve --open --config ./devServer/webpack.config.js",
		"start:devGateway": "node ./devServer/start-devGateway.js",
		"start:codespace": "node --max-old-space-size=4096 ./node_modules/.bin/env-cmd -f .env.dev webpack serve --open --config ./devServer/webpack.config.js --no-hot",
		"validate:assets": "node ./devServer/validate-assets.js",
		"prebuild": "npm run validate:assets",
		"build:dev": "env-cmd -f .env.dev webpack --config ./devServer/webpack.config.js --output-path ../release/app --mode production --progress",
		"analyze": "env-cmd -f .env.dev webpack --config ./devServer/webpack.config.js --mode production --env analyze",
		"prettier": "prettier --write ../",
		"test:e2e": "npx playwright test --project chromium --headed",
		"test:e2e:ui": "npx playwright test --ui",
		"test:e2e:smoke": "npx playwright test --project chromium --headed --grep smoke",
		"test:e2e:debug": "npx playwright test --project chromium --debug",
		"test:e2e:report": "npx playwright show-report"
	},
	"dependencies": {
		"@fabric-msft/fabric-react": "^7.4.0",
		"@fabric-msft/fabric-web": "^7.4.0",
		"@fabric-msft/theme": "^5.3.0",
		"@fluentui/react-components": "^9.7.2",
		"@fluentui/react-icons": "2.0.226",
		"@microsoft/applicationinsights-web": "^3.4.2",
		"@ms-fabric/workload-client": "^2.3.0",
		"dompurify": "^3.4.7",
		"history": "^4.9.0",
		"i18next": "^23.12.3",
		"i18next-http-backend": "^4.0.0",
		"jwt-decode": "^3.1.2",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"react-i18next": "^15.0.1",
		"react-router-dom": "^5.3.4",
		"scheduler": "^0.23.0",
		"uuid": "^11.1.1",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.0-alpha-2026-01-23",
		"@trivago/prettier-plugin-sort-imports": "^6.0.0",
		"@types/node": "^16.0.0",
		"@types/react": "^18.0.0",
		"@types/react-dom": "^18.0.0",
		"@types/react-router-dom": "^5.3.2",
		"@types/yup": "^0.29.14",
		"ajv": "^8.12.0",
		"copy-webpack-plugin": "^10.0.0",
		"css-loader": "^6.5.1",
		"dotenv": "^17.3.1",
		"env-cmd": "^10.1.0",
		"express-rate-limit": "^7.5.1",
		"html-webpack-plugin": "^5.5.0",
		"prettier": "^3.6.2",
		"sass": "^1.79.3",
		"sass-loader": "^16.0.2",
		"style-loader": "^3.3.1",
		"ts-loader": "^9.2.6",
		"typescript": "^5.0.4",
		"webpack": "^5.90.3",
		"webpack-bundle-analyzer": "^4.10.2",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^5.2.5"
	},
	"overrides": {
		"minimatch": ">=10.2.4",
		"picomatch": ">=4.0.2",
		"serialize-javascript": ">=7.0.5",
		"brace-expansion": ">=5.0.6",
		"uuid": "^11.1.1"
	}
}
