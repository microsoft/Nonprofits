# The workload name should be alligned with the name defined in the WorkloadManifest.xml
WORKLOAD_NAME={{WORKLOAD_NAME}}
# Azure AD configuration for the frontend application
DEV_AAD_CONFIG_FE_APPID={{FRONTEND_APP_ID}}
# The development workspace GUID that the DevGateway is registering
DEV_WORKSPACE_ID={{DEV_WORKSPACE_ID}}
# Comma-separated workspace IDs where workspace-move simulation UI is enabled
WORKSPACE_MOVE_SIMULATION_WORKSPACE_IDS=
# Enable debug mode
DEBUG_MODE_ENABLED=false
# Telemetry is disabled by default in the open-source build. Set TELEMETRY_DISABLED=false
# and provide an Application Insights connection string to enable explicit event telemetry.
TELEMETRY_DISABLED=true
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=
APPLICATIONINSIGHTS_ENDPOINT_URL=